(async () => {
  const BRN_VALUE = "12345678"; // ← 改这里

  const sleep = (ms) => new Promise(r => setTimeout(r, ms));

  async function waitFor(fn, timeout = 20000, interval = 200) {
    const start = Date.now();
    while (Date.now() - start < timeout) {
      const v = fn();
      if (v) return v;
      await sleep(interval);
    }
    return null;
  }

  async function clickSel(selector, timeout = 20000) {
    const el = await waitFor(() => document.querySelector(selector), timeout);
    if (!el) throw new Error(`未找到元素: ${selector}`);
    el.scrollIntoView({ block: "center" });
    el.dispatchEvent(new MouseEvent("mousedown", { bubbles: true }));
    el.dispatchEvent(new MouseEvent("mouseup", { bubbles: true }));
    el.dispatchEvent(new MouseEvent("click", { bubbles: true }));
    return el;
  }

  function clickButtonByText(text) {
    const btn = [...document.querySelectorAll("button")]
      .find(b => (b.innerText || "").includes(text));
    if (!btn) return false;
    btn.scrollIntoView({ block: "center" });
    btn.dispatchEvent(new MouseEvent("click", { bubbles: true }));
    return true;
  }

  function clickSpanByText(text) {
    const el = [...document.querySelectorAll("span")]
      .find(s => (s.textContent || "").includes(text));
    if (!el) return false;
    el.scrollIntoView({ block: "center" });
    el.dispatchEvent(new MouseEvent("click", { bubbles: true }));
    return true;
  }

  function setReactInputValueById(id, value) {
    const el = document.getElementById(id);
    if (!el) return false;

    const setter = Object.getOwnPropertyDescriptor(HTMLInputElement.prototype, "value")?.set;
    if (!setter) return false;

    setter.call(el, value);
    el.dispatchEvent(new Event("input", { bubbles: true }));
    el.dispatchEvent(new Event("change", { bubbles: true }));
    el.dispatchEvent(new Event("blur", { bubbles: true }));
    return true;
  }

  // ===== 1) 跑你给的流程 =====
  // 跳转 /verification
  const link = document.querySelector('a[href="/verification"]');
  if (!link) throw new Error('未找到 a[href="/verification"]');
  link.click();

  await sleep(2500);

  // Get Started
  await clickSel('[data-testid="get-started-button"]', 30000);
  await sleep(300);

  // 填 BRN（React 兼容）
  const okSet = await waitFor(() => setReactInputValueById("BusinessRegistrationNumber", BRN_VALUE), 15000);
  if (!okSet) throw new Error("未找到/未成功设置 BusinessRegistrationNumber 输入框");

  // Review selection
  // 注意：你之前截图里是 review-selection-button_available / review-selection-button-available，
  // 这里做个兼容（优先 available）
  const reviewBtn =
    document.querySelector('[data-testid="review-selection-button-available"]') ||
    document.querySelector('[data-testid="review-selection-button_available"]');

  if (!reviewBtn) throw new Error("未找到 review-selection-button(-available/_available)");
  reviewBtn.click();

  await sleep(200);

  // Generate Report
  const clickedGenerate = clickButtonByText("Generate Report");
  if (!clickedGenerate) throw new Error("未找到 Generate Report 按钮");
  await sleep(8000);

  // Additional data tab
  const clickedAdditional = clickButtonByText("Additional data");
  if (!clickedAdditional) {
    // 有时是 span/tab，也做个兜底
    const ok = clickSpanByText("Additional data");
    if (!ok) throw new Error("未找到 Additional data");
  }
  await sleep(400);

  // BusinessDetails
  const okBD = clickSpanByText("BusinessDetails");
  if (!okBD) throw new Error("未找到 BusinessDetails");
  await sleep(400);

  // ===== 2) 检测 3 项（Key Info / Abnormal / Change Records）+ 抓 Transaction record ID =====

  async function waitContainerStable(container, maxMs = 7000) {
    const start = Date.now();
    let last = "";
    let stable = 0;
    while (Date.now() - start < maxMs) {
      const now = (container.innerText || "").trim();
      if (now && now === last) stable++;
      else stable = 0;
      last = now;
      if (stable >= 2) break;
      await sleep(200);
    }
  }

  function clickCategory(label) {
    const el = [...document.querySelectorAll("span.categoryName")]
      .find(s => (s.textContent || "").trim().toLowerCase().includes(label.toLowerCase()));
    if (!el) return false;
    el.scrollIntoView({ block: "center" });
    el.dispatchEvent(new MouseEvent("click", { bubbles: true }));
    return true;
  }

  function hasRealContent(container) {
    // 1) Key Info 常见结构：div(style padding-bottom) > b(字段名) + 值
    const kvBlocks = container.querySelectorAll('div[style*="padding-bottom"] > b');
    if (kvBlocks.length > 0) return true;

    // 2) Table 结构：有 tbody tr 且里面有 td 文本
    const rows = [...container.querySelectorAll("table tbody tr")];
    const hasRowText = rows.some(tr => (tr.innerText || "").trim().length > 0);
    if (rows.length > 0 && hasRowText) return true;

    // 3) 兜底：去掉标题(dataTitle)和 copy 后还有剩余文本
    const clone = container.cloneNode(true);
    clone.querySelectorAll("b.dataTitle, button.copyTitle").forEach(n => n.remove());
    const cleaned = (clone.innerText || "").replace(/\bcopy\b/gi, "").trim();
    return cleaned.length > 0;
  }

  function extractKeyValues(container) {
    const kv = {};
    const blocks = [...container.querySelectorAll('div[style*="padding-bottom"]')];
    for (const block of blocks) {
      const b = block.querySelector("b");
      if (!b) continue;
      const key = (b.textContent || "").trim();
      const raw = (block.innerText || "").trim();
      const value = raw.replace(key, "").replace(/^[:：\s]+/, "").trim();
      if (key) kv[key] = value;
    }
    return kv;
  }

  // 抓 Transaction record ID：点击 View all → 读弹窗里的 Transaction record ID
  function clickViewAll() {
    const btn = [...document.querySelectorAll("button")]
      .find(b => (b.innerText || "").includes("View all"));
    if (!btn) return false;
    btn.scrollIntoView({ block: "center" });
    btn.dispatchEvent(new MouseEvent("click", { bubbles: true }));
    return true;
  }

  function getTxnId() {
    const title = [...document.querySelectorAll("span")]
      .find(el => (el.textContent || "").trim() === "Transaction record ID:");
    return title?.nextElementSibling?.textContent?.trim() || null;
  }

  async function getTxnIdViaModal() {
    const clicked = clickViewAll();
    if (!clicked) return null;

    const ok = await waitFor(() => getTxnId(), 15000);
    if (!ok) return null;

    await sleep(200);
    return getTxnId();
  }

  const container = await waitFor(
    () => document.querySelector('[data-testid="additional-data-appended-div"]'),
    20000
  );
  if (!container) throw new Error("❌ 未找到右侧容器 additional-data-appended-div");

  const targets = [
    { name: "Key Info", match: "Key Information" },
    { name: "Abnormal", match: "Abnormal" },
    { name: "Change Records", match: "Change Records" }
  ];

  const results = [];

  for (const t of targets) {
    const ok = clickCategory(t.match) || clickSpanByText(t.match) || clickSpanByText(t.name);
    if (!ok) {
      results.push({ item: t.name, found: false, hasContent: null, note: "左侧未找到该项" });
      continue;
    }

    await sleep(300);
    await waitContainerStable(container, 7000);

    const has = hasRealContent(container);
    const row = { item: t.name, found: true, hasContent: has };

    if (t.name === "Key Info" && has) row.sample = extractKeyValues(container);
    results.push(row);
  }

  // Transaction record ID 写入表
  const txnId = await getTxnIdViaModal();
  for (const r of results) r.transactionRecordId = txnId || null;

  console.table(results);
  if (txnId) console.log("Transaction record ID:", txnId);
  else console.log("⚠️ 未获取到 Transaction record ID（可能找不到 View all 或弹窗里没有该字段）");

})();
