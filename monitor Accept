javascript:(()=>{console.log("👀 开始监听 Accept...");const clickLikeUser=(el)=>{el.scrollIntoView?.({block:"center"});el.dispatchEvent(new MouseEvent("mousedown",{bubbles:true}));el.dispatchEvent(new MouseEvent("mouseup",{bubbles:true}));el.dispatchEvent(new MouseEvent("click",{bubbles:true}));};const findAccept=()=>[...document.querySelectorAll("a,button,[role='button']")].find(el=>el.textContent&&el.textContent.trim()==="Accept");const tryClick=()=>{const el=findAccept();if(el){clickLikeUser(el);console.log("✅ 已自动点击 Accept");observer.disconnect();}};const observer=new MutationObserver(()=>{tryClick();});observer.observe(document.body,{childList:true,subtree:true});tryClick();})()
